---
import { Book, Plus, Info, SunMoon } from '@lucide/astro';

interface Props {
  mobileMenuType?: 'standard' | 'score-edit';
}
const { mobileMenuType = 'standard' } = Astro.props;
---

<header>
  <div class="header-left">
    <a href="/" class="logo">
      <div class="logo-icon">ロ</div>
    </a>
    <div class="header-metadata">
      <slot name="header-metadata" />
    </div>
  </div>
  <div class="header-right">
    <slot name="header-actions" />
    <div class="header-nav-separator" aria-hidden="true"></div>
    <!-- Desktop navigation (hidden on mobile) -->
    <div class="header-desktop-nav">
      <a
        href="/"
        class="btn btn-icon"
        aria-label="View scores"
      >
        <Book size={16} stroke-width={2} />
      </a>
      <button
        id="desktop-create-btn"
        class="btn btn-icon"
        aria-label="Create new score"
      >
        <Plus size={16} stroke-width={2} />
      </button>
      <a
        href="/about"
        class="btn btn-icon"
        aria-label="About"
      >
        <Info size={16} stroke-width={2} />
      </a>
      <button id="theme-toggle" class="btn btn-icon" aria-label="Toggle theme">
        <SunMoon size={16} stroke-width={2} />
      </button>
      <div id="auth-widget">
        <button id="auth-login" class="btn btn-small btn-primary">
          <span class="btn-text">Log In</span>
        </button>
        <button id="auth-signup" class="btn btn-small btn-neutral">
          <span class="btn-text">Sign Up</span>
        </button>
        <button id="auth-avatar" class="btn btn-icon auth-avatar-btn"
          hidden aria-label="Account menu" aria-expanded="false" aria-haspopup="menu">
          <span class="btn-text" id="auth-initials"></span>
        </button>
      </div>
    </div>
    <!-- Mobile menu (shown on mobile) -->
    <div id="mobile-menu" class="mobile-menu-container" data-menu-type={mobileMenuType}>
      <button id="mobile-menu-toggle" class="btn btn-icon" aria-label="Menu" aria-expanded="false">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  import { initHeader } from '../utils/init-header';
  initHeader();
</script>

<style>
  header {
    padding: var(--spacing-medium) var(--spacing-medium);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .header-left {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-x-small);
    min-width: 0; /* allow shrinking below content size to prevent header overflow */
  }

  .header-metadata {
    align-self: center;
    min-width: 0; /* needed so the inner flex content can wrap */
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: var(--spacing-x-small);
    flex-shrink: 0; /* nav/auth always fully visible; header-left absorbs overflow via wrapping */
  }

  /* Desktop navigation - hide on mobile */
  .header-desktop-nav {
    display: flex;
    align-items: center;
    gap: var(--spacing-x-small);
  }

  /* Mobile menu - hide on desktop */
  .mobile-menu-container {
    display: none;
  }

  /* Logo */
  .logo {
    text-decoration: none;
  }
  .logo-icon {
    width: var(--logo-width);
    height: var(--logo-height);
    color: var(--color-logo);
    border-radius: var(--logo-border-radius);
    font-size: var(--logo-character-size);
    text-align: center;
    line-height: var(--line-height-denser);
    font-weight: var(--logo-font-weight);
    border: var(--logo-border-width) solid var(--color-logo);
    box-sizing: border-box;
  }

  #theme-toggle {
    flex-shrink: 0;
  }

  /* Auth widget */
  #auth-widget {
    flex-shrink: 0;
    display: flex;
    gap: var(--spacing-x-small);
  }

  .header-nav-separator {
    width: 1px;
    height: 1em; /* matches icon size (1em = 16px at base font) */
    background: var(--color-border);
    flex-shrink: 0;
  }

  /* Hide separator when no header-actions precede it */
  .header-right > .header-nav-separator:first-child {
    display: none;
  }

  @media (max-width: 768px) {
    header {
      gap: var(--spacing-small);
    }

    .header-left {
      align-items: flex-start;
      gap: var(--spacing-small);
      flex: 1;
    }

    /* Default: centering container for title-only case */
    .header-metadata {
      display: flex;
      align-items: center;
      min-height: var(--size-toolbar-item);
    }

    /* Override when metadata has 2+ children (title + metadata present) */
    .header-left:has(.score-header-metadata > :nth-child(2)) .header-metadata {
      align-items: flex-start;
      margin-top: 3px; /* visual nudge — aligns title cap-height with logo center; between --spacing-3x-small (2px) and --spacing-2x-small (4px) */
    }

    .header-right {
      justify-content: flex-end;
      flex-shrink: 0;
      gap: var(--spacing-small);
    }

    /* Hide desktop navigation on mobile */
    .header-desktop-nav {
      display: none;
    }

    .header-nav-separator {
      display: none;
    }

    /* Show mobile menu on mobile */
    .mobile-menu-container {
      display: block;
    }
  }
</style>
