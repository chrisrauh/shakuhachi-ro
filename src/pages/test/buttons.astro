---
import Layout from '../../layouts/Layout.astro';
import { Book, Plus, Info } from '@lucide/astro';

const title = 'Button Components';
---

<Layout title={title} currentPage="browse">
  <div class="buttons-test-page">
    <h1>Button Components Test Page</h1>

    <div class="test-grid">
      <!-- Icon Buttons -->
      <section class="test-section">
        <h2>Icon Buttons (32x32px)</h2>
        <div class="compact-row">
          <div class="btn-sample">
            <button class="btn btn-icon" aria-label="Default icon">
              <Book size={16} />
            </button>
            <span>Default</span>
          </div>
          <div class="btn-sample">
            <button class="btn btn-icon btn-primary" aria-label="Primary icon">
              <Plus size={16} />
            </button>
            <span>Primary</span>
          </div>
          <div class="btn-sample">
            <button class="btn btn-icon btn-neutral" aria-label="Neutral icon">
              <Info size={16} />
            </button>
            <span>Neutral</span>
          </div>
          <div class="btn-sample">
            <button class="btn btn-icon" disabled aria-label="Disabled icon">
              <Book size={16} />
            </button>
            <span>Disabled</span>
          </div>
        </div>
      </section>

      <!-- Small Buttons -->
      <section class="test-section">
        <h2>Small Buttons</h2>
        <div class="compact-row">
          <div class="btn-sample">
            <button class="btn btn-small btn-primary"><span class="btn-text">Primary</span></button>
            <span>Primary</span>
          </div>
          <div class="btn-sample">
            <button class="btn btn-small btn-secondary"><span class="btn-text">Secondary</span></button>
            <span>Secondary</span>
          </div>
          <div class="btn-sample">
            <button class="btn btn-small btn-success"><span class="btn-text">Success</span></button>
            <span>Success</span>
          </div>
          <div class="btn-sample">
            <button class="btn btn-small btn-neutral"><span class="btn-text">Neutral</span></button>
            <span>Neutral</span>
          </div>
          <div class="btn-sample">
            <button class="btn btn-small btn-ghost"><span class="btn-text">Ghost</span></button>
            <span>Ghost</span>
          </div>
          <div class="btn-sample">
            <button class="btn btn-small btn-primary" disabled><span class="btn-text">Disabled</span></button>
            <span>Disabled</span>
          </div>
        </div>
      </section>

      <!-- Standard Buttons -->
      <section class="test-section">
        <h2>Standard Buttons</h2>
        <div class="compact-row">
          <div class="btn-sample">
            <button class="btn btn-primary"><span class="btn-text">Primary</span></button>
            <span>Primary</span>
          </div>
          <div class="btn-sample">
            <button class="btn btn-secondary"><span class="btn-text">Secondary</span></button>
            <span>Secondary</span>
          </div>
          <div class="btn-sample">
            <button class="btn btn-success"><span class="btn-text">Success</span></button>
            <span>Success</span>
          </div>
          <div class="btn-sample">
            <button class="btn btn-neutral"><span class="btn-text">Neutral</span></button>
            <span>Neutral</span>
          </div>
          <div class="btn-sample">
            <button class="btn btn-ghost"><span class="btn-text">Ghost</span></button>
            <span>Ghost</span>
          </div>
          <div class="btn-sample">
            <button class="btn btn-primary" disabled><span class="btn-text">Disabled</span></button>
            <span>Disabled</span>
          </div>
        </div>
      </section>

      <!-- Counter Button -->
      <section class="test-section">
        <h2>Counter Button</h2>
        <div class="compact-row">
          <div class="btn-sample">
            <button class="btn-icon-with-count">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3"/>
                <path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"/>
              </svg>
              <span class="count">123</span>
            </button>
            <span>Counter</span>
          </div>
          <div class="btn-sample">
            <button class="btn-icon-with-count" disabled>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M15 3h6v6M14 10l6.1-6.1M9 21H3v-6m6 0l-6.1 6.1"/>
              </svg>
              <span class="count">42</span>
            </button>
            <span>Disabled</span>
          </div>
        </div>
      </section>

      <!-- State Comparison -->
      <section class="test-section">
        <h2>State Comparison</h2>
        <div class="state-comparison">
          <div class="state-row">
            <span class="state-label">Primary:</span>
            <button class="btn btn-primary"><span class="btn-text">Default</span></button>
            <button class="btn btn-primary" disabled><span class="btn-text">Disabled</span></button>
          </div>
          <div class="state-row">
            <span class="state-label">Secondary:</span>
            <button class="btn btn-secondary"><span class="btn-text">Default</span></button>
            <button class="btn btn-secondary" disabled><span class="btn-text">Disabled</span></button>
          </div>
          <div class="state-row">
            <span class="state-label">Success:</span>
            <button class="btn btn-success"><span class="btn-text">Default</span></button>
            <button class="btn btn-success" disabled><span class="btn-text">Disabled</span></button>
          </div>
          <div class="state-row">
            <span class="state-label">Ghost:</span>
            <button class="btn btn-ghost"><span class="btn-text">Default</span></button>
            <button class="btn btn-ghost" disabled><span class="btn-text">Disabled</span></button>
          </div>
        </div>
      </section>

      <!-- Alignment Test -->
      <section class="test-section">
        <h2>Alignment & Sizing</h2>
        <div class="alignment-test">
          <button class="btn btn-icon" aria-label="Icon">
            <Book size={16} />
          </button>
          <button class="btn btn-small btn-primary"><span class="btn-text">Small</span></button>
          <button class="btn btn-primary"><span class="btn-text">Standard</span></button>
          <button class="btn-icon-with-count">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 3h6v6M14 10l6.1-6.1M9 21H3v-6m6 0l-6.1 6.1"/>
            </svg>
            <span class="count">99</span>
          </button>
        </div>
      </section>
    </div>
  </div>
</Layout>

<style>
  .buttons-test-page {
    max-width: 1200px;
    margin: 0 auto;
  }

  h1 {
    font-size: var(--font-size-2x-large);
    margin-bottom: var(--spacing-medium);
    margin-top: 0px;
    color: var(--color-text-primary);
  }

  h2 {
    font-size: var(--font-size-medium);
    margin-bottom: var(--spacing-small);
    color: var(--color-text-primary);
    font-weight: var(--font-weight-semibold);
  }

  .test-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-medium);
  }

  .test-section {
    padding: var(--spacing-medium);
    background: var(--color-bg-subtle);
    border-radius: var(--border-radius-medium);
    border: 1px solid var(--color-border);
  }

  .compact-row {
    display: flex;
    gap: var(--spacing-small);
    flex-wrap: wrap;
  }

  .btn-sample {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-x-small);
  }

  .btn-sample > span {
    font-size: var(--font-size-x-small);
    color: var(--color-text-secondary);
  }

  .state-comparison {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-small);
  }

  .state-row {
    display: flex;
    align-items: center;
    gap: var(--spacing-small);
  }

  .state-label {
    min-width: 80px;
    font-size: var(--font-size-small);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }

  .alignment-test {
    display: flex;
    align-items: center;
    gap: var(--spacing-small);
  }

  /* Fix counter button font to use proper CSS font stack instead of Arial */
  .btn-icon-with-count .count {
    font-family: var(--font-sans);
  }

  @media (max-width: 768px) {
    .test-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { ThemeSwitcher } from '../../components/ThemeSwitcher';

  new ThemeSwitcher('theme-switcher');
</script>
