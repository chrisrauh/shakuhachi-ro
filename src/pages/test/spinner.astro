---
import Layout from '../../layouts/Layout.astro';
import { buildSpinnerSVG, buildButtonSpinnerSVG } from '../../components/LoadingSpinner';

const title = 'Loading Spinner';
const spinner = buildSpinnerSVG();
const btnSpinner = buildButtonSpinnerSVG();
---

<Layout title={title} currentPage="browse">
  <div class="spinner-test-page">
    <h1>Loading Spinner</h1>
    <p>Shakuhachi fingering holes — Ri → Chi → Re → Tsu → Ro → reverse</p>

    <section class="demo-section">
      <div class="demo-row">
        <div class="demo-item">
          <div data-spinner-host set:html={spinner} />
        </div>
        <div class="demo-item demo-inverted">
          <div data-spinner-host set:html={spinner} />
        </div>
      </div>
    </section>

    <section class="demo-section">
      <h2>In Buttons</h2>
      <p>Click each button to toggle loading state.</p>
      <div class="button-demo-row">
        <button class="btn btn-primary" data-btn-demo data-loading-text="Loading…">
          Load
        </button>
        <button class="btn btn-secondary" data-btn-demo>
          Save
        </button>
        <button class="btn btn-danger" data-btn-demo data-loading-text="Deleting…">
          Delete
        </button>
        <button class="btn btn-primary btn-sm" data-btn-demo data-loading-text="Saving…">
          Small
        </button>
        <button class="btn btn-icon btn-primary" aria-label="Trigger loading" data-btn-demo data-icon-btn>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        </button>
        <button class="btn btn-icon" aria-label="Trigger loading" data-btn-demo data-icon-btn>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </button>
      </div>
    </section>

    <section class="demo-section">
      <h2>Loading States</h2>
      <p>Static examples — already in loading state.</p>
      <div class="button-demo-row">
        <button class="btn btn-primary loading" disabled aria-busy="true" set:html={`${btnSpinner}\nSaving…`} />
        <button class="btn btn-secondary loading" disabled aria-busy="true" set:html={`${btnSpinner}\nLoading…`} />
        <button class="btn btn-danger loading" disabled aria-busy="true" set:html={`${btnSpinner}\nDeleting…`} />
        <button class="btn btn-primary btn-sm loading" disabled aria-busy="true" set:html={`${btnSpinner}\nSaving…`} />
        <button class="btn btn-icon btn-primary loading" aria-label="Loading" disabled aria-busy="true" set:html={btnSpinner} />
        <button class="btn btn-icon loading" aria-label="Loading" disabled aria-busy="true" set:html={btnSpinner} />
      </div>
    </section>

  </div>
</Layout>

<style>
  .spinner-test-page {
    padding: 2rem;
    max-width: 860px;
    margin: 0 auto;
    padding: 0;
  }

  .spinner-test-page h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0;
    margin-top: 0;
  }

  .spinner-test-page > p {
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .demo-section {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.75rem 1.25rem;
  }

  .demo-row {
    display: flex;
    gap: 0;
  }

  .demo-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 50%;
    padding: 2rem;
  }

  .demo-inverted {
    background: var(--color-text-primary);
    color: var(--page-background-color);
    border-radius: 0 6px 6px 0;
  }

  .demo-section + .demo-section {
    margin-top: 0.75rem;
  }

  .demo-section h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    margin-top:0;;
  }

  .demo-section > p {
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .button-demo-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

</style>

<script>
  import { Pane } from 'tweakpane';
  import { buildSpinnerSVG, buildButtonSpinnerSVG, ButtonLoadingState } from '../../components/LoadingSpinner';

  // Default params (match buildSpinnerSVG defaults)
  const params = {
    radius: 8,
    gap: 8,
    strokeWidth: 0,
    stepDuration: 0.5,
    fadeIn: 0.5,
    fadeOut: 0.5,
  };

  function updateAll() {
    const svg = buildSpinnerSVG({
      r: params.radius,
      gap: params.gap,
      strokeWidth: params.strokeWidth,
      stepDuration: params.stepDuration,
      fadeIn: params.fadeIn,
      fadeOut: params.fadeOut,
    });
    document.querySelectorAll('[data-spinner-host]').forEach((el) => {
      el.innerHTML = svg;
    });
  }

  const pane = new Pane({ title: 'Spinner params' });
  const paneEl = pane.element.closest('.tp-dfwv') as HTMLElement;
  if (paneEl) {
    paneEl.style.top = 'auto';
    paneEl.style.bottom = '1rem';
  }
  pane
    .addBinding(params, 'radius', { label: 'radius (px)', min: 0, max: 16, step: 0.5 })
    .on('change', updateAll);
  pane
    .addBinding(params, 'gap', { label: 'gap (px)', min: 0, max: 16, step: 0.5 })
    .on('change', updateAll);
  pane
    .addBinding(params, 'strokeWidth', { label: 'stroke (px)', min: 0, max: 3, step: 0.1 })
    .on('change', updateAll);
  pane
    .addBinding(params, 'stepDuration', { label: 'step (s)', min: 0, max: 1.5, step: 0.05 })
    .on('change', updateAll);
  pane
    .addBinding(params, 'fadeIn', { label: 'fade-in (s)', min: 0, max: 1, step: 0.01 })
    .on('change', updateAll);
  pane
    .addBinding(params, 'fadeOut', { label: 'fade-out (s)', min: 0, max: 1, step: 0.01 })
    .on('change', updateAll);

  // Button spinner params
  const btnParams = {
    radius: 6,
    strokeWidth: 0,
    stepDuration: 0.65,
  };

  function updateButtonSpinners() {
    const svg = buildButtonSpinnerSVG({
      r: btnParams.radius,
      strokeWidth: btnParams.strokeWidth,
      stepDuration: btnParams.stepDuration,
    });
    // Update spinners inside any button currently in loading state
    document.querySelectorAll('.btn.loading svg').forEach((el) => {
      el.outerHTML = svg;
    });
  }

  const btnPane = new Pane({ title: 'Button spinner params' });
  const btnPaneEl = btnPane.element.closest('.tp-dfwv') as HTMLElement;
  if (btnPaneEl) {
    btnPaneEl.style.top = 'auto';
    btnPaneEl.style.bottom = '1rem';
    btnPaneEl.style.right = '260px';
  }
  btnPane
    .addBinding(btnParams, 'radius', { label: 'radius (px)', min: 2, max: 16, step: 0.5 })
    .on('change', updateButtonSpinners);
  btnPane
    .addBinding(btnParams, 'strokeWidth', { label: 'stroke (px)', min: 0, max: 3, step: 0.1 })
    .on('change', updateButtonSpinners);
  btnPane
    .addBinding(btnParams, 'stepDuration', { label: 'step (s)', min: 0, max: 1.5, step: 0.05 })
    .on('change', updateButtonSpinners);

  // Toggle button loading state on click
  document.querySelectorAll<HTMLElement>('[data-btn-demo]').forEach((btn) => {
    const state = new ButtonLoadingState(btn);
    let loading = false;
    btn.addEventListener('click', () => {
      if (loading) {
        state.hide();
      } else {
        state.show();
      }
      loading = !loading;
    });
  });
</script>
