---
import Layout from '../../../layouts/Layout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import { getScoreBySlug } from '../../../api/scores';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/');

const scoreResult = await getScoreBySlug(slug);
const { score } = scoreResult;

// 404 if score not found (no more create mode via this route)
if (!score) return new Response(null, { status: 404 });
---

<Layout title={`Edit ${score.title}`} currentPage="score" fullHeight={true}>
  <PageHeader slot="header-metadata" title={`Edit ${score.title}`} />

  <div class="edit-layout">
    <div class="mobile-toggle">
      <button id="toggle-preview" class="btn"><span class="btn-text">Preview</span></button>
      <button id="toggle-editor" class="btn btn-primary"><span class="btn-text">Edit</span></button>
    </div>

    <div class="preview-panel" id="preview-panel">
      <div id="score-preview"></div>
    </div>

    <div class="editor-panel" id="editor-panel">
      <div id="score-editor"></div>
    </div>
  </div>

  <!-- Always embed score data — safe because 404 above ensures score is non-null -->
  <script id="score-data" type="application/json" is:inline set:html={JSON.stringify({ score })}></script>

  <script is:inline src="/embed/shakuhachi-score.js"></script>

  <script>
    import { ScoreEditor } from '../../../components/ScoreEditor';
    import { onAuthReady } from '../../../api/auth';
    import { toast } from '../../../components/Toast';
    import { STRINGS } from '../../../constants/strings';

    // Simplified auth check — no "create mode" branch
    const checkAuthAndPermissions = (user: any) => {
      const scoreData = JSON.parse(document.getElementById('score-data')!.textContent!);

      if (!user) {
        window.location.href = `/score/${scoreData.score.slug}`;
        return;
      }

      if (user.id !== scoreData.score.user_id) {
        toast.error(STRINGS.ERRORS.ScoreEditor.editPermissionDenied, { duration: 2000 });
        setTimeout(() => {
          window.location.href = `/score/${scoreData.score.slug}`;
        }, 2000);
        return;
      }
    };

    onAuthReady((user) => {
      checkAuthAndPermissions(user);
    });

    // scoreId and slug always present — SSR 404 above ensures page is never served without a score
    const scoreData = JSON.parse(document.getElementById('score-data')!.textContent!);
    new ScoreEditor('score-editor', scoreData.score.id, scoreData.score.slug);
  </script>

  <style>
    .edit-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-large);
      height: calc(100vh - 80px);
      padding: var(--spacing-medium);
    }

    .mobile-toggle { display: none; }

    .preview-panel,
    .editor-panel {
      overflow-y: auto;
      min-height: 0;
      height: 100%;
    }

    .preview-panel {
      border: var(--panel-border-width) solid var(--panel-border-color);
      border-radius: var(--border-radius-large);
      background: var(--panel-background-color);
      padding: var(--spacing-large);
    }

    #score-preview {
      width: 100%;
      min-height: 100%;
    }

    @media (max-width: 768px) {
      .edit-layout {
        grid-template-columns: 1fr;
        grid-template-rows: auto 1fr;
        padding: var(--spacing-medium);
      }

      .mobile-toggle {
        display: flex;
        gap: var(--spacing-small);
        margin-bottom: var(--spacing-medium);
      }

      .mobile-toggle button { flex: 1; }

      .preview-panel.hidden,
      .editor-panel.hidden { display: none; }
    }
  </style>

  <script>
    const togglePreview = document.getElementById('toggle-preview');
    const toggleEditor = document.getElementById('toggle-editor');
    const previewPanel = document.getElementById('preview-panel');
    const editorPanel = document.getElementById('editor-panel');

    togglePreview?.addEventListener('click', () => {
      previewPanel?.classList.remove('hidden');
      editorPanel?.classList.add('hidden');
      togglePreview.classList.add('btn-primary');
      toggleEditor?.classList.remove('btn-primary');
    });

    toggleEditor?.addEventListener('click', () => {
      editorPanel?.classList.remove('hidden');
      previewPanel?.classList.add('hidden');
      toggleEditor.classList.add('btn-primary');
      togglePreview?.classList.remove('btn-primary');
    });

    if (window.innerWidth < 768) {
      previewPanel?.classList.add('hidden');
    }
  </script>
</Layout>
