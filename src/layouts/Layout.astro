---
import SiteHeader from '../components/SiteHeader.astro';
import '../styles/tokens/themes.css';
import '../styles/components.css';

interface Props {
  title: string;
  currentPage: 'browse' | 'create' | 'score';
  fullHeight?: boolean;
  noPadding?: boolean;
  mobileMenuType?: 'standard' | 'score-edit';
}

const { title, currentPage: _currentPage, fullHeight = false, noPadding = false, mobileMenuType } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100..900&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon-light.svg" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href="/favicon-dark.svg" media="(prefers-color-scheme: dark)" />
    <script is:inline>
      // Prevent flash of wrong theme - runs before body renders
      (function() {
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
      })();
    </script>
  </head>
  <body class={fullHeight ? 'full-height' : ''}>
    <SiteHeader mobileMenuType={mobileMenuType}>
      <slot name="header-metadata" slot="header-metadata" />
      <slot name="header-actions" slot="header-actions" />
    </SiteHeader>

    <main class={noPadding ? 'no-padding' : ''}>
      <slot />
    </main>

    <!-- Dev Tools (only rendered in dev mode) -->
    {import.meta.env.DEV && (
      <div class="dev-controls">
        <div id="letter-spacing-control" class="dev-panel"></div>
      </div>
    )}

    <style is:global>
      /* ONLY OVERRIDE: Font family to use Noto Sans JP */
      :root {
        --font-sans: 'Noto Sans JP', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: var(--font-sans);
        background: var(--page-background-color);
        color: var(--color-text-primary);
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
        letter-spacing: var(--letter-spacing-override, normal);
      }

      body.full-height {
        height: 100vh;
        display: flex;
        flex-direction: column;
      }

      body.full-height main {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        padding: 0;
      }

      /* On mobile, revert to natural document scrolling */
      @media (max-width: 768px) {
        body.full-height {
          height: auto;
          min-height: 100vh;
        }

        body.full-height main {
          flex: none;
          overflow: visible;
        }
      }

      main {
        padding: var(--spacing-medium);
      }

      main.no-padding {
        padding: 0;
      }

      /* Loading state for Plus button */
      .btn.loading {
        opacity: 0.6;
        pointer-events: none;
      }

      /* Dev controls - fixed column stack, bottom-right */
      .dev-controls {
        position: fixed;
        bottom: var(--spacing-medium);
        right: var(--spacing-medium);
        z-index: 100;
        display: flex;
        flex-direction: column;
        gap: var(--spacing-x-small);
        max-width: 280px;
      }

      /* Dev panel - individual panel within the stack */
      .dev-panel { }

      /* Tweakpane theme integration */
      .dev-panel :global(.tp-dfwv) {
        min-width: 240px;
      }

      .dev-panel :global(.tp-rotv_c) {
        background-color: var(--color-bg-subtle);
        border: 1px solid var(--color-border);
        border-radius: var(--border-radius-medium);
      }

      .dev-panel :global(.tp-lblv_l) {
        color: var(--color-text-primary);
      }

      .dev-panel :global(.tp-brkv) {
        background-color: var(--color-bg-active);
      }
    </style>

  </body>
</html>
